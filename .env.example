# ── Security ─────────────────────────────────────────────────────────────────
# CRITICAL: Generate strong SECRET_KEY for production
# Example: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=django-insecure-replace-with-real-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS settings
CORS_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DB_NAME=sheber_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=

# CORS settings
CORS_ALLOW_ALL=True

# Быстрый старт без Docker/PostgreSQL (только для разработки)
# Поставь true чтобы использовать SQLite вместо PostgreSQL
USE_SQLITE=true

# ── Production only (Railway) ───────────────────────────────────────────────
# URL прод-фронтенда — нужен для CORS. Дефолт в config/settings/production.py
# уже указывает на боевой Vercel-домен, переопределять нужно только при смене домена.
FRONTEND_URL=https://i-hostel-ten.vercel.app

# Sentry DSN — трекинг ошибок в проде. Опционально: без него Sentry просто не активируется.
SENTRY_DSN=

